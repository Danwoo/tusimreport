# Developer / CI tooling.
#
# Separate from requirements.in so the production image does not need them.
# Install with:
#   pip install -r requirements-dev.txt
# (or pip install -r requirements.txt -r requirements-dev.txt)
#
# Regenerate the pinned dev lockfile with:
#   pip-compile --resolver=backtracking requirements-dev.in -o requirements-dev.txt


# ====================================
# tusimreport v2.3 환경 변수 설정
# ====================================
# 이 파일을 복사하여 .env 파일을 생성하세요
# cp .env.example .env

# ====================================
# LLM API 설정 (필수)
# ====================================

# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here
USE_GEMINI=true
GEMINI_MODEL=gemini-2.0-flash-lite

# OpenAI API (Fallback)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
# 올바른 모델명:
# - gpt-4o (최신, 권장)
# - gpt-4o-mini (저렴한 옵션)
# - gpt-4-turbo (이전 버전)

# ====================================
# 한국 공식 데이터 API 키 (필수)
# ====================================

# 금융감독원 전자공시시스템 (DART)
# 발급: https://opendart.fss.or.kr/
DART_API_KEY=your_dart_api_key_here

# 한국은행 경제통계시스템 (ECOS)
# 발급: https://ecos.bok.or.kr/
ECOS_API_KEY=your_ecos_api_key_here

# 통계청 국가통계포털 (KOSIS) - 현재 미사용
# KOSIS_SERVICE_KEY=your_kosis_key_here

# ====================================
# 뉴스 데이터 API 키 (필수)
# ====================================

# Naver Developers API
# 발급: https://developers.naver.com/apps/#/register
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# Tavily Search API (글로벌 뉴스)
# 발급: https://tavily.com/
# 무료: 1,000건/월
TAVILY_API_KEY=your_tavily_api_key_here

# ====================================
# LangSmith Tracing (선택사항)
# ====================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=korean-stock-analysis

# ====================================
# Notion Integration (선택사항)
# ====================================
NOTION_API_TOKEN=your_notion_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ====================================
# MCP Server Settings (선택사항)
# ====================================
MCP_NOTION_URL=https://mcp.notion.com/mcp

# ====================================
# Application Settings
# ====================================
DEBUG=True
LOG_LEVEL=WARNING
STREAMLIT_PORT=8501

# ====================================
# 주의사항
# ====================================
# 1. .env 파일은 절대 Git에 커밋하지 마세요
# 2. API 키가 노출되면 즉시 재발급하세요
# 3. 무료 API 할당량을 확인하세요:
#    - Tavily: 1,000건/월
#    - Naver: 25,000건/일

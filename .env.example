# ============================================
# TuSimReport 환경 설정 파일
# ============================================
# 이 파일을 복사하여 .env로 저장하고 실제 값을 입력하세요
# cp .env.example .env
# ============================================

# ============================================
# LLM API 설정 (필수 - 둘 중 하나 이상)
# ============================================

# Google Gemini API (권장)
# 발급: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API (대체)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# LLM 모델 선택
USE_GEMINI=true
GEMINI_MODEL=gemini-2.0-flash-lite
OPENAI_MODEL=gpt-4.1-nano

# ============================================
# 한국 금융 데이터 API (필수)
# ============================================

# DART API (금융감독원 전자공시)
# 발급: https://opendart.fss.or.kr/
# 필요성: 기업 재무제표, 공시 정보
DART_API_KEY=your_dart_api_key_here

# ECOS API (한국은행 경제통계)
# 발급: https://ecos.bok.or.kr/
# 필요성: 거시경제 지표 (기준금리, GDP 등)
ECOS_API_KEY=your_ecos_api_key_here

# ============================================
# 뉴스 API (권장 - 감정 분석용)
# ============================================

# Naver 뉴스 검색 API (한국 뉴스)
# 발급: https://developers.naver.com/products/search/
# 필요성: 한국어 뉴스 감정 분석
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# Tavily Search API (글로벌 뉴스)
# 발급: https://tavily.com/
# 필요성: 영문 뉴스 및 글로벌 시장 분석 (선택)
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# 애플리케이션 설정
# ============================================

# 디버그 모드 (개발: true, 프로덕션: false)
DEBUG=true

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# 자동 데이터 소스 (API 키 불필요)
# ============================================
# 다음 데이터 소스는 별도 API 키 없이 작동합니다:
# - FinanceDataReader: 한국/미국 주가 데이터
# - PyKRX: 한국거래소 공식 데이터
# - Paxnet 크롤링: 커뮤니티 감정 분석 (Selenium)

# ============================================
# 최소 요구사항
# ============================================
# 기본 작동을 위한 최소 API 키:
# 1. GOOGLE_API_KEY 또는 OPENAI_API_KEY (필수)
# 2. DART_API_KEY (필수)
# 3. ECOS_API_KEY (필수)
#
# 권장 API 키 (더 나은 분석):
# 4. NAVER_CLIENT_ID + NAVER_CLIENT_SECRET
# 5. TAVILY_API_KEY

# ============================================
# 주의사항
# ============================================
# - 이 파일(.env)은 절대 Git에 커밋하지 마세요
# - API 키는 외부에 노출되지 않도록 주의하세요
# - 무료 API는 호출 제한이 있을 수 있습니다
